{
  "name": "transpak-backend",
  "version": "1.0.0",
  "description": "TransPak backend (Express + PostgreSQL + JWT)",
  "engines": {
    "node": ">=18 <23"
  },
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "start": "node server.js",
    "build": "node scripts/verify-upload-deps.js && node --check server.js && node --check src/server.js && node --check src/app.js",
    "test": "node --test test/*.test.js",
    "test:smoke": "node --test test/smoke.api.test.js",
    "test:rbac": "node --test test/rbac.test.js",
    "test:security": "node --test test/security.ownership.test.js",
    "test:phase1": "node --test test/security.ownership.test.js test/phase1-signoff.test.js",
    "test:expiry": "node --test test/expiry.marketplace.test.js",
    "test:concurrency": "node --test test/concurrency.bid-accept.test.js",
    "test:phase7": "node --test test/phase7.state-machine.test.js test/phase7.static.test.js test/phase7.integration.test.js test/realtime.dedupe.test.js test/concurrency.bid-accept.test.js test/notifications.api.test.js test/security.ownership.test.js",
    "test:phase7:attack": "node scripts/phase7-attack-simulation.mjs",
    "test:phase8": "node --test test/phase8.static.test.js",
    "check:production": "node scripts/phase8-production-readiness.mjs",
    "test:notifications": "node --test test/notifications.api.test.js",
    "test:performance": "node --test test/performance.safety.test.js",
    "test:safety": "node --test test/*.test.js",
    "seed": "node scripts/seedUsers.js",
    "seed:demo-admin": "node scripts/seedDemoAdmin.js",
    "seed:phase1-rbac": "node scripts/seedPhase1RbacUsers.js",
    "check:login": "node scripts/runtime-login-check.js",
    "check:schema": "node scripts/qa-schema-check.js",
    "check:api-smoke": "node scripts/qa-api-smoke.js",
    "check:ors": "node scripts/verify-ors-route.js",
    "check:e2e-flow": "node scripts/e2e-flow-check.mjs",
    "db:migrate:otp": "node scripts/applyOtpMigrations.js",
    "db:migrate": "node scripts/run-migrations.js",
    "db:ensure-notifications": "node scripts/ensureNotificationSchema.js",
    "db:debug-schema": "node scripts/debug-schema-state.js",
    "verify:production": "node scripts/verify-production-alignment.mjs",
    "dev:reset-test-auth": "node scripts/devResetTestAuth.js",
    "deploy:check": "node ../scripts/check-production-sync.mjs",
    "deploy:qa": "node ../scripts/final-production-qa.mjs",
    "deploy:smoke": "node ../scripts/live-smoke-test.mjs"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
