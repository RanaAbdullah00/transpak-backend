{
  "name": "transpak-backend",
  "version": "1.0.0",
  "description": "TransPak backend (Express + PostgreSQL + JWT)",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "start": "node server.js",
    "build": "node --check server.js && node --check src/server.js && node --check src/app.js",
    "test": "node --test",
    "seed": "node scripts/seedUsers.js",
    "seed:admin": "node scripts/seedUsers.js",
    "db:migrate:otp": "node scripts/applyOtpMigrations.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
