# --- Core (Render / Railway / local) ---
# Render/Railway set PORT automatically. Locally you may set PORT=5000 in .env; that does NOT block port fallback.
# Port fallback (try 5001, 5002, …) runs in NODE_ENV=development when not on a PaaS, unless ALLOW_PORT_FALLBACK=false.
# On Render, RAILWAY_ENVIRONMENT, Fly, or Cloud Run, PORT is locked (no fallback). Optional: FORCE_PLATFORM_PORT=true.
PORT=5000
NODE_ENV=development

# BIND_HOST=0.0.0.0

# ALLOW_PORT_FALLBACK=false

# --- PostgreSQL ---
# Production: set DATABASE_URL from your host (Render Postgres, Railway, Neon, etc.).
# SSL is auto-enabled for common cloud URLs; set PGSSL=false to force plain TCP when using DATABASE_URL.
# PG_CONNECTION_TIMEOUT_MS=10000
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=transpak
PGUSER=postgres
PGPASSWORD=

# DB reconnect tuning (optional)
# DB_RETRY_BASE_MS=5000
# DB_RETRY_MAX_QUICK=8
# DB_RETRY_SLOW_MS=120000

# --- CORS & frontend (required in production for browser + Socket.io) ---
# Comma-separated list, no spaces required: https://your-app.onrender.com,https://www.yourdomain.com
# You may also use FRONTEND_URL or VITE_APP_ORIGIN (single URL each); all are merged.
CORS_ORIGIN=http://localhost:5173
# FRONTEND_URL=https://transpak-frontend.onrender.com

# --- JWT ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Cloudinary (media storage) ---
# Prefer CLOUDINARY_URL. Alternatively set CLOUDINARY_CLOUD_NAME/CLOUDINARY_API_KEY/CLOUDINARY_API_SECRET.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: POST /api/example-upload/image (Bearer token + multipart field "image") — off by default
ENABLE_EXAMPLE_UPLOAD=false

# Optional: log redacted register body to console (development or when true)
# AUTH_DEBUG_REGISTER=false

# Optional: self-hosted LibreTranslate base URL (no trailing slash). If unset, /api/translations/runtime returns passthrough.
# LIBRETRANSLATE_URL=http://localhost:5001
# TRANSLATION_TIMEOUT_MS=8000
# TRANSLATION_MAX_CHARS=4000
# TRANSLATION_CACHE_MAX=600
# TRANSLATION_RATE_LIMIT_PER_MIN=45

# Uploads (Cloudinary via /api/upload/*)
# UPLOAD_RATE_LIMIT_PER_MIN=30
# UPLOAD_IMAGE_MAX_BYTES=5242880
# UPLOAD_PDF_MAX_BYTES=10485760

# --- Email OTP (Nodemailer / Brevo) ---
#
# Health: GET /health (no DB required for process liveness). API: GET /api/health (includes DB flag).
#
# Apply OTP SQL once (from transpak-backend folder):
#   npm run db:migrate:otp
#
# API routes (POST, prefix /api/auth):
#   /otp/register/verify   body: { email, code }
#   /otp/register/resend  body: { email }
#   /otp/forgot/send      body: { email }
#   /otp/forgot/reset     body: { email, code, password, confirmPassword }
#   /send-otp /verify-otp /resend-otp  (generic auth OTP)
#   /otp/smtp-ping        body: { to?: email } — prod needs header x-smtp-test-secret: $SMTP_TEST_SECRET
#
# Brevo: use the SMTP relay key from Dashboard → SMTP & API → SMTP (NOT the xkeysib REST API key).
# Aliases: BREVO_EMAIL + BREVO_SMTP_KEY, or SMTP_USER + SMTP_PASS.
#
# SMTP_DEBUG_LOG=true — verbose SMTP logs (temporary ops).
# SMTP_TEST_SECRET=long_random_string — required in production for POST /otp/smtp-ping.
#
# OTP_EXPIRY_MINUTES: integer 5–10 (default 8).
# SMTP_CONNECTION_TIMEOUT_MS: 5000–120000 (default 20000).
#
# Production: set SMTP_HOST, SMTP_USER, SMTP_PASS (or Brevo aliases), and SMTP_FROM (or MAIL_FROM / BREVO_EMAIL).
# SMTP_VERIFY_ON_START=true runs nodemailer.verify() once at startup (logs only; never crashes the process).
# PGSSL_REJECT_UNAUTHORIZED=true — optional strict TLS when PGSSL=true / DATABASE_SSL=true.

# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# BREVO_EMAIL=
# BREVO_SMTP_KEY=
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=TransPak <verified@yourdomain.com>
# SMTP_FROM=TransPak <verified@yourdomain.com>
# SMTP_ALLOW_USER_AS_FROM=false
# OTP_EXPIRY_MINUTES=8
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_VERIFY_ON_START=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_DEBUG_LOG=false
# SMTP_TEST_SECRET=
# OTP_DEV_RETURN=false

# --- Render / Railway checklist ---
# 1. Web service: build npm install && npm run build ; start npm start ; health check path /health
# 2. Set DATABASE_URL, JWT_SECRET, NODE_ENV=production, CORS_ORIGIN (your deployed frontend URL)
# 3. Same CORS_ORIGIN must match the browser origin that opens Socket.io (same site or explicit URL)
# 4. Render (free): Blueprint at repo root `../render.yaml` (monorepo) or `render.yaml` here if this folder is the Git root.
#    Run once after deploy: `npm run db:migrate:otp` in the Render Shell. Set CORS_ORIGIN to your frontend URL.
