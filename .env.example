# --- Core (Render / Railway / local) ---
# Local: PORT=5000 is fine. On Render, do NOT add PORT in the dashboard — Render injects it (required for https://…onrender.com).
# RENDER_EXTERNAL_URL / RENDER are detected so the server never tries PORT+1 on the host (only one port is routed).
# Port fallback (5001, 5002…) applies on your laptop when not on a PaaS, unless ALLOW_PORT_FALLBACK=false.
PORT=10000
# Local laptop: use development so CORS allows all Vite ports. Render sets production automatically.
NODE_ENV=development

# BIND_HOST=0.0.0.0

# ALLOW_PORT_FALLBACK=false

# --- PostgreSQL (single variable; PGHOST/PGPORT/PGUSER/PGPASSWORD are not used) ---
# PG_CONNECTION_TIMEOUT_MS=30000
#
# Supabase: copy URI from Dashboard → Connect. Prefer Session pooler on IPv4 networks.
# https://supabase.com/docs/guides/database/connecting-to-postgres
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.grlwewofaqjdcsqtasoe:transpak%401234@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# DB reconnect tuning (optional)
# DB_RETRY_BASE_MS=5000
# DB_RETRY_MAX_QUICK=8
# DB_RETRY_SLOW_MS=120000
# After wrong Supabase password / ECIRCUITBREAKER, wait this long before retry (default 300000 = 5 min).
# DB_RETRY_CIRCUIT_MS=300000
# Optional pool size (default 10).
# PG_POOL_MAX=10

# --- CORS & frontend (required in production for browser + Socket.io) ---
# Comma-separated list, no spaces required: https://your-app.onrender.com,https://www.yourdomain.com
# You may also use FRONTEND_URL or VITE_APP_ORIGIN (single URL each); all are merged.
# Production example (Cloudflare Pages + Render API origin if you need it). No trailing slashes.
# CORS_ORIGIN=https://20f26555.transpak-frontend.pages.dev,https://transpak-backend-1.onrender.com
# Local default:
CORS_ORIGIN=https://89bf14c5.transpak-frontend.pages.dev
# Extra allowed origins (comma-separated). e.g. local Vite when CORS_ORIGIN is production URLs only:
# CORS_EXTRA_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# --- JWT ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Cloudinary (media storage) ---
# Prefer CLOUDINARY_URL. Alternatively set CLOUDINARY_CLOUD_NAME/CLOUDINARY_API_KEY/CLOUDINARY_API_SECRET.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Optional: POST /api/example-upload/image (Bearer token + multipart field "image") — off by default
ENABLE_EXAMPLE_UPLOAD=false

# Optional: log redacted register body to console (development or when true)
# AUTH_DEBUG_REGISTER=false
# Log JWT vs DB role on each authenticated request (dev only)
# AUTH_DEBUG=true

# --- FYP demo admin (disabled when NODE_ENV=production unless ENABLE_TRANSPAK_DEMO_ADMIN=true) ---
# Local laptop with NODE_ENV=production in .env: set ENABLE_TRANSPAK_DEMO_ADMIN=true or use NODE_ENV=development.
# ENABLE_TRANSPAK_DEMO_ADMIN=false
# TRANSPAK_DEMO_ADMIN_EMAIL=mrrajpoot.327@gmail.com
# TRANSPAK_DEMO_ADMIN_PASSWORD=change_me_in_dev_only
# TRANSPAK_DEMO_ADMIN_PHONE=+923001234568
# TRANSPAK_DEMO_ADMIN_CNIC=00000-0000000-0

# --- Dev-only auth testing (NEVER enable on production) ---
# DEV_MODE=true — honored ONLY when NODE_ENV is not production. With DEV_AUTH_TEST_EMAILS, allowlisted
# addresses get: OTP/pending cleared before each signup OTP, resend cooldown bypass, generic /send-otp
# reset, wrong-password "re-register" becomes password reset + unverify for retesting.
# DEV_AUTH_TEST_EMAILS=you@example.com,other@test.local
#
# CLI reset (clears pending_registrations + email_otp_challenges + auth_otp_codes for one email):
#   npm run dev:reset-test-auth -- --email=you@example.com
# Optional: --unverify-user | --delete-user (delete only if email is in DEV_AUTH_TEST_EMAILS)

# Optional: self-hosted LibreTranslate base URL (no trailing slash). If unset, /api/translations/runtime returns passthrough.
# LIBRETRANSLATE_URL=http://localhost:5001
# TRANSLATION_TIMEOUT_MS=8000
# TRANSLATION_MAX_CHARS=4000
# TRANSLATION_CACHE_MAX=600
# TRANSLATION_RATE_LIMIT_PER_MIN=45

# Uploads (Cloudinary via /api/upload/*)
# UPLOAD_RATE_LIMIT_PER_MIN=30
# UPLOAD_IMAGE_MAX_BYTES=5242880
# UPLOAD_PDF_MAX_BYTES=10485760
# UPLOAD_MEDIA_MAX_BYTES=26214400
# UPLOAD_STREAM_TIMEOUT_MS=60000
# UPLOAD_MAX_RETRIES=2

# --- Email OTP (Brevo HTTP API) ---
#
# Apply OTP SQL once: npm run db:migrate:otp
#
# Required on Render:
#   BREVO_API_KEY — REST API key (xkeysib-…) from Brevo → SMTP & API (not the xsmtpsib SMTP key)
#   BREVO_SENDER_EMAIL — verified sender address in Brevo (Senders & IP)
#
# Optional:
#   BREVO_VERIFY_ON_START=true — GET /v3/account at boot (non-fatal)
#   BREVO_DEBUG_LOG=true — verbose send logs
#   OTP_EXPIRY_MINUTES=8
#   OTP_DEV_RETURN=true — return OTP in API response (development only)
#   SMTP_TEST_SECRET=… — required in production for POST /api/auth/otp/smtp-ping (diagnostic)
#
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# OTP_EXPIRY_MINUTES=8
# BREVO_VERIFY_ON_START=false
# BREVO_DEBUG_LOG=false
# SMTP_TEST_SECRET=
# OTP_DEV_RETURN=false

# --- Load fare (recommended = fuel + platform margin) ---
# fuelCost ≈ distanceKm × FUEL_LITERS_PER_KM × FUEL_PRICE_PER_LITER × vehicleMultiplier
# suggestedFare = fuelCost + FARE_PLATFORM_MARGIN_PKR + (fuelCost × FARE_PLATFORM_MARGIN_PERCENT / 100)
# FUEL_LITERS_PER_KM=0.35
# FUEL_PRICE_PER_LITER=280
# FARE_PLATFORM_MARGIN_PKR=500
# FARE_PLATFORM_MARGIN_PERCENT=10
# LOAD_DEFAULT_DISTANCE_KM=50

# --- OpenRouteService (server-side only — never put in VITE_* or frontend) ---
# Get a key at https://openrouteservice.org/dev/#/signup
# ORS_API_KEY=
# ORS_CACHE_MS=900000
# ORS_TIMEOUT_MS=12000
# MAPS_RATE_LIMIT_PER_MIN=40
# SHIPMENTS_RATE_LIMIT_PER_MIN=120
# BIDS_RATE_LIMIT_PER_MIN=80
# GPS_UPDATE_MIN_INTERVAL_MS=10000
# REQUEST_LOG_ALL=false

# Notification queue (in-memory, per process)
# NOTIFY_SOCKET_FLUSH_MS=400
# NOTIFY_DEDUPE_MS=120000
# JSON_BODY_LIMIT=5mb

# --- Render / Railway checklist ---
# 1. Web service: build npm install && npm run build ; start npm start ; health check path /health
# 2. Set DATABASE_URL, JWT_SECRET, NODE_ENV=production, CORS_ORIGIN (your deployed frontend URL)
# 3. Same CORS_ORIGIN must match the browser origin that opens Socket.io (same site or explicit URL)
# 4. Render (free): Blueprint at repo root `../render.yaml` (monorepo) or `render.yaml` here if this folder is the Git root.
#    Run once after deploy: `npm run db:migrate:otp` in the Render Shell. Set CORS_ORIGIN to your frontend URL.
