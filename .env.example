PORT=5000
NODE_ENV=development

# If false (default), the server exits when PORT is busy instead of binding 5001/5002 (Vite expects 5000).
# Set true only if you intentionally run multiple backends and update frontend VITE_PROXY_TARGET.
# ALLOW_PORT_FALLBACK=false

# PostgreSQL (preferred: DATABASE_URL). Example:
# DATABASE_URL=postgresql://postgres:1254@127.0.0.1:5432/transpak
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=transpak
PGUSER=postgres
# Must match your local Postgres user password (example for this machine: 1254)
PGPASSWORD=1254

# DB reconnect tuning (optional)
# DB_RETRY_BASE_MS=5000
# DB_RETRY_MAX_QUICK=8
# DB_RETRY_SLOW_MS=120000

# Cloudinary (media storage)
# Prefer CLOUDINARY_URL. Alternatively set CLOUDINARY_CLOUD_NAME/CLOUDINARY_API_KEY/CLOUDINARY_API_SECRET.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: POST /api/example-upload/image (Bearer token + multipart field "image") — off by default
ENABLE_EXAMPLE_UPLOAD=false

# Optional: log redacted register body to console (development or when true)
# AUTH_DEBUG_REGISTER=false

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# For local dev with Vite (adjust as needed)
CORS_ORIGIN=http://localhost:5173

# Optional: self-hosted LibreTranslate base URL (no trailing slash). If unset, /api/translations/runtime returns passthrough.
# LIBRETRANSLATE_URL=http://127.0.0.1:5001
# TRANSLATION_TIMEOUT_MS=8000
# TRANSLATION_MAX_CHARS=4000
# TRANSLATION_CACHE_MAX=600
# TRANSLATION_RATE_LIMIT_PER_MIN=45

# Uploads (Cloudinary via /api/upload/*)
# UPLOAD_RATE_LIMIT_PER_MIN=30
# UPLOAD_IMAGE_MAX_BYTES=5242880
# UPLOAD_PDF_MAX_BYTES=10485760

# --- Email OTP (Nodemailer) — registration + forgot password ---
#
# Apply DB migration once (from repo root or adjust path):
#   psql "%DATABASE_URL%" -f transpak-backend/db/migrations/004_email_otp_challenges.sql
#   # macOS/Linux: psql "$DATABASE_URL" -f transpak-backend/db/migrations/004_email_otp_challenges.sql
#
# API routes (POST, prefix /api/auth):
#   /otp/register/verify   body: { email, code }
#   /otp/register/resend  body: { email }
#   /otp/forgot/send      body: { email }
#   /otp/forgot/reset     body: { email, code, password, confirmPassword }
#   /otp/smtp-ping        body: { to?: email } — same SMTP as OTP; prod needs header x-smtp-test-secret: $SMTP_TEST_SECRET
#
# Brevo (Sendinblue): use the SMTP **relay key** from Dashboard → SMTP & API → SMTP (NOT the xkeysib REST API key).
# Typical: SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, SMTP_SECURE=false, SMTP_USER=your Brevo login email,
# SMTP_PASS=your SMTP key. MAIL_FROM must use a sender/domain verified under Senders & IP (Gmail as From often hurts deliverability).
# If SMTP returns 250 but Gmail never shows the mail, check Brevo transactional logs + recipient spam; that is not the same as SMTP reject.
#
# SMTP_DEBUG_LOG=true — logs full SMTP response line, accepted/rejected arrays on success; richer error logs on failure (temporary ops).
# SMTP_TEST_SECRET=long_random_string — required in production to call POST /otp/smtp-ping (header x-smtp-test-secret).
#
# Gmail: use smtp.gmail.com:587, SMTP_SECURE=false, and an App Password (not your normal password).
#
# OTP_EXPIRY_MINUTES: integer 5–10 (default 8). Codes are bcrypt-hashed in DB; hashes are never returned in JSON.
# SMTP_CONNECTION_TIMEOUT_MS: 5000–120000 (default 20000). Prevents hung SMTP connections.
#
# Production checklist: NODE_ENV=production, and all of SMTP_HOST, SMTP_USER, SMTP_PASS, plus SMTP_FROM
# (or legacy MAIL_FROM). In production the From header must be set via SMTP_FROM or MAIL_FROM unless you set
# SMTP_ALLOW_USER_AS_FROM=true (uses SMTP_USER as From — less ideal for deliverability).
# Port 465 uses implicit TLS; 587 uses STARTTLS (set SMTP_SECURE=false for 587).
# Optional: SMTP_TLS_REJECT_UNAUTHORIZED=false only for broken dev certs (not recommended in production).
# Optional: SMTP_VERIFY_ON_START=true runs nodemailer.verify() once at startup (logs success/failure).
# Leave SMTP_HOST unset in dev: OTP is logged to the server console on send failure (NODE_ENV !== production only).
# OTP_DEV_RETURN=true (non-production only): success JSON may include devOtp — never enable in production.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_gmail_app_password
# MAIL_FROM=TransPak <youraddress@gmail.com>
# SMTP_FROM=TransPak <youraddress@gmail.com>
# SMTP_ALLOW_USER_AS_FROM=false
# OTP_EXPIRY_MINUTES=8
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_VERIFY_ON_START=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_DEBUG_LOG=false
# SMTP_TEST_SECRET=
# OTP_DEV_RETURN=false

