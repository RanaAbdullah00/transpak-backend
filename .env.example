# --- Core (Render / Railway / local) ---
# Local: PORT=5000 is fine. On Render, do NOT add PORT in the dashboard — Render injects it (required for https://…onrender.com).
# RENDER_EXTERNAL_URL / RENDER are detected so the server never tries PORT+1 on the host (only one port is routed).
# Port fallback (5001, 5002…) applies on your laptop when not on a PaaS, unless ALLOW_PORT_FALLBACK=false.
PORT=10000
# Local laptop: use development so CORS allows all Vite ports. Render sets production automatically.
NODE_ENV=development

# BIND_HOST=0.0.0.0

# ALLOW_PORT_FALLBACK=false

# --- PostgreSQL (single variable; PGHOST/PGPORT/PGUSER/PGPASSWORD are not used) ---
# PG_CONNECTION_TIMEOUT_MS=30000
#
# Supabase: copy URI from Dashboard → Connect. Prefer Session pooler on IPv4 networks.
# https://supabase.com/docs/guides/database/connecting-to-postgres
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Render: set the SAME Supabase URI in Dashboard → Environment (not a separate empty Postgres unless you migrate it).
# Deploy to Render (required — production only updates from GitHub):
#   npm run predeploy:check   # fails if uncommitted backend files
#   git push origin main
#   Render Dashboard → Manual Deploy → Clear build cache
#   npm run verify:production
# Logs must show: [deploy] commit=<full-sha> [deploy] time=<iso>
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# DB reconnect tuning (optional)
# DB_RETRY_BASE_MS=5000
# DB_RETRY_MAX_QUICK=8
# DB_RETRY_SLOW_MS=120000
# After wrong Supabase password / ECIRCUITBREAKER, wait this long before retry (default 300000 = 5 min).
# DB_RETRY_CIRCUIT_MS=300000
# Optional pool size (default 10).
# PG_POOL_MAX=10

# --- CORS & frontend (required in production for browser + Socket.io) ---
# Comma-separated list, no spaces required: https://your-app.onrender.com,https://www.yourdomain.com
# You may also use FRONTEND_URL or VITE_APP_ORIGIN (single URL each); all are merged.
# Production example (Cloudflare Pages + Render API origin if you need it). No trailing slashes.
# Any https://*.transpak-frontend.pages.dev origin is also auto-allowed by the API (preview deploy hashes).
# CORS_ORIGIN=https://20f26555.transpak-frontend.pages.dev,https://transpak-backend-1.onrender.com
# Local default:
CORS_ORIGIN=https://1c7c2150.transpak-frontend.pages.dev
# Extra allowed origins (comma-separated). e.g. local Vite when CORS_ORIGIN is production URLs only:
# CORS_EXTRA_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# --- JWT ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
ENABLE_EXAMPLE_UPLOAD=false

# --- Automated safety tests (npm test) ---
# QA_BASE_URL=http://127.0.0.1:10000
# E2E_SHIPPER_EMAIL=
# E2E_SHIPPER_PASSWORD=
# E2E_CARRIER_EMAIL=
# E2E_CARRIER_PASSWORD=
# E2E_CARRIER2_EMAIL=
# E2E_CARRIER2_PASSWORD=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=

# Phase 1 isolated RBAC (run: npm run seed:phase1-rbac)
# PHASE1_RBAC_PASSWORD=
# E2E_SHIPPER_ONLY_EMAIL=transpak.phase1.shipper@example.com
# E2E_CARRIER_ONLY_EMAIL=transpak.phase1.carrier@example.com
# E2E_ADMIN_ONLY_EMAIL=transpak.phase1.admin@example.com

# --- Phase 8 — ops / rate limits (optional) ---
# OPS_SLOW_REQUEST_MS=2000
# NOTIFICATIONS_RATE_LIMIT_PER_MIN=100
# GPS_UPDATE_MIN_INTERVAL_MS=10000
# GPS_SOCKET_MAX_PER_MIN=90
# Integration test harness only (run-all-tests.mjs sets this when API is up). Never enable in production.
# DISABLE_LOGIN_RATE_LIMIT=1
# Presentation / demo parity: relax vehicle-type bid blocks (warn only, do not 409).
# Must match Render env for consistent load board + bid behavior.
ALLOW_VEHICLE_TYPE_MISMATCH=true
# JSON_BODY_LIMIT=5mb
# NOTIFY_SOCKET_FLUSH_MS=400

# --- Bids: single-round negotiation (carrier suggest once → shipper accept/reject) ---
# BID_MAX_COUNTER_ROUNDS=1
# When true (default), carrier bid at listed fare auto-books without shipper accept step.
# BID_AUTO_ACCEPT_LISTED_FARE=true

# --- Phase 7 — strict distributed control (optional) ---
# REDIS_URL=redis://...
# ENABLE_STRICT_DISTRIBUTED=true
# DISTRIBUTED_MODE=multi
# CAUSAL_RECONSTRUCT_ORPHANS=true
# CHAOS_ENABLED=1
